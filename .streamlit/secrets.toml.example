# Copy to .streamlit/secrets.toml (locally) or paste into the Streamlit Cloud
# "Secrets" settings for your app. NEVER commit the real secrets.toml.
#
# Optional: provisions an authenticated Instagram session for everyone using the
# deployed app, so age-restricted / sensitive / private content and full 1080p
# media work without anyone pasting a sessionid by hand.
#
# How to get the value: log in to instagram.com in a desktop browser, open
# DevTools (F12) > Application > Cookies > instagram.com, copy the `sessionid`.
IG_SESSIONID = "paste-your-sessionid-cookie-here"
